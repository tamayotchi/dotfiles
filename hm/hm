#!/usr/bin/env bash
set -euo pipefail

CONFIG_PATH="${HM_MCP_CONFIG_PATH:-$HOME/hm/.pi/mcp.json}"
CACHE_DIR="$HOME/.cache/hm"
LOG_FILE="$CACHE_DIR/ha-mcp-web.log"
STARTED_SERVER_PID=""

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "hm: required command not found: $1" >&2
    exit 1
  fi
}

read_ha_env() {
  python - "$CONFIG_PATH" <<'PY'
import json
import os
import sys

path = os.path.expanduser(sys.argv[1])
if not os.path.exists(path):
    print(f"hm: MCP config not found: {path}", file=sys.stderr)
    sys.exit(1)

with open(path, "r", encoding="utf-8") as f:
    data = json.load(f)

server = (data.get("mcpServers") or {}).get("home-assistant")
if not server:
    print(f"hm: home-assistant MCP server is not configured in {path}", file=sys.stderr)
    sys.exit(1)

env = server.get("env") or {}
url = env.get("HOMEASSISTANT_URL")
token = env.get("HOMEASSISTANT_TOKEN")
if not url or not token:
    print("hm: HOMEASSISTANT_URL or HOMEASSISTANT_TOKEN missing in MCP config", file=sys.stderr)
    sys.exit(1)

print(url)
print(token)
PY
}

start_server() {
  require_cmd uvx
  mkdir -p "$CACHE_DIR"

  mapfile -t ha_env < <(read_ha_env)
  export HOMEASSISTANT_URL="${ha_env[0]}"
  export HOMEASSISTANT_TOKEN="${ha_env[1]}"

  if pgrep -f "[h]a-mcp-web" >/dev/null 2>&1; then
    echo "hm: reusing existing Home Assistant MCP web server" >&2
    return 0
  fi

  echo "hm: starting temporary Home Assistant MCP web server..." >&2
  uvx --from ha-mcp@latest ha-mcp-web >>"$LOG_FILE" 2>&1 &
  STARTED_SERVER_PID="$!"
}

cleanup() {
  if [[ -n "$STARTED_SERVER_PID" ]] && kill -0 "$STARTED_SERVER_PID" >/dev/null 2>&1; then
    echo "hm: stopping temporary Home Assistant MCP web server..." >&2
    kill "$STARTED_SERVER_PID" >/dev/null 2>&1 || true
    wait "$STARTED_SERVER_PID" 2>/dev/null || true
  fi
}

build_prompt() {
  local base="Use the Home Assistant MCP server named 'home-assistant' in this session. Reconnect it if needed, then help me with my Home Assistant instance."
  if (($# == 0)); then
    printf "%s Ask me what I want to do.\n" "$base"
  else
    printf "%s My first request is: %s\n" "$base" "$*"
  fi
}

main() {
  trap cleanup EXIT INT TERM HUP

  require_cmd pi
  start_server

  if [[ "${HM_NO_CHAT:-0}" == "1" ]]; then
    echo "hm: Home Assistant MCP server ready. Log: $LOG_FILE"
    exit 0
  fi

  cd "$HOME"
  pi "$(build_prompt "$@")"
}

main "$@"
